PYTHONBREAKPOINT=ipdb.set_trace
SENTRY_DSN=""

EMAIL_FROM_ADDRESS=noreply@jangubi.sn
ADMIN_ACCOUNT_EXPIRY_DAYS=7

# Email sending — valeurs de dev (MailHog)
EMAIL_SENDING_STRATEGY=mailhog
MAILHOG_HOST=mailhog
MAILHOG_PORT=1025

FILE_UPLOAD_STRATEGY="direct" # pass-thru
FILE_UPLOAD_STORAGE="local" # s3

AWS_S3_ACCESS_KEY_ID=""
AWS_S3_SECRET_ACCESS_KEY=""
AWS_STORAGE_BUCKET_NAME=""
AWS_S3_REGION_NAME=""
AWS_S3_CUSTOM_DOMAIN=""

DJANGO_GOOGLE_OAUTH2_CLIENT_ID=""
DJANGO_GOOGLE_OAUTH2_CLIENT_SECRET=""
DJANGO_GOOGLE_OAUTH2_PROJECT_ID=""

# --- Recherche sémantique & RAG (GRATUIT) ---------------------------------
# Par défaut : recherche lexicale (FTS) + RAG extractif. Aucun coût.
# Pour ACTIVER la recherche sémantique vectorielle (embeddings locaux gratuits) :
#   1) EMBEDDING_PROVIDER=local et PGVECTOR_ENABLED=True
#   2) (re)indexer les embeddings (compute_embeddings_task par livre, ou re-seed)
# Le 1er usage télécharge le modèle (~1 Go) dans FASTEMBED_CACHE_DIR.
EMBEDDING_PROVIDER=local
PGVECTOR_ENABLED=True
# FASTEMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# FASTEMBED_CACHE_DIR=/app/.cache/fastembed

# Génération LLM (OPTIONNELLE — le RAG marche sans). Laisser off pour rester gratuit.
RAG_GENERATION_ENABLED=False
GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-2.5-flash
